#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Validate conventional commit format using Node.js inline script
MSG_FILE="$1"
node -e "
const fs = require('fs');
const msg = fs.readFileSync(process.argv[1], 'utf8').trim();
const pattern = /^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9_-]+\))?!?: .+/;
const lines = msg.split('\n').filter(l => !l.startsWith('#'));
const firstLine = lines[0] || '';
if (!pattern.test(firstLine)) {
  console.error('commit-msg: invalid format. Expected: type(scope?): description');
  console.error('Valid types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert');
  console.error('Got:', firstLine);
  process.exit(1);
}
process.exit(0);
" "$MSG_FILE"
